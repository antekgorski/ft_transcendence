# Environment Configuration
# Copy this file to .env and update the values with your actual credentials

# Django Settings
DEBUG=False
ALLOWED_HOSTS=example.com
SECRET_KEY=your-secret-key-here-generate-a-strong-random-string

# Neon PostgreSQL Database (replace with your actual Neon credentials)
DB_NAME=name_of_your_neon_db
DB_USER=your-neon-username-here
DB_PASSWORD=your-neon-password-here
DB_HOST=your-neon-host-here
DB_PORT=your-neon-port-here
DB_SSLMODE=require

# Redis Configuration (used for game state management and caching)
REDIS_PASSWORD=your-redis-password-here

# Backend Settings
BACKEND_HOST=number_of_your_backend_host
BACKEND_PORT=your_backend_port

# CORS Settings (update with your frontend URL)
CORS_ALLOWED_ORIGINS=http://example.com:1234

# Frontend Settings
REACT_APP_API_URL=http://example.com/api

# JWT Settings (optional - configure as needed)
# JWT_SECRET_KEY=your-jwt-secret-key
# JWT_ACCESS_TOKEN_LIFETIME=60
# JWT_REFRESH_TOKEN_LIFETIME=1440

# 42 API Credentials
FORTY_TWO_CLIENT_ID=your_42_client_id_here
FORTY_TWO_CLIENT_SECRET=your_42_client_secret_here
FORTY_TWO_REDIRECT_URI=http://example.com/api/auth/oauth/42/callback/